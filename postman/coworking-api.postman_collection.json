    {
      "name": "Reserva em sala inexistente (99) -> 404",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"salaId\":99,\"data\":\"2026-06-01\",\"horaInicio\":\"14:00\",\"horaFim\":\"15:00\",\"responsavel\":\"Z\",\"email\":\"z@z.com\"}" },
        "url": { "raw": "{{baseUrl}}/reservas", "host": ["{{baseUrl}}"], "path": ["reservas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 404', () => pm.response.to.have.status(404));"
      ] } }]
    },
    {
      "name": "Agenda do dia -> 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/reservas?data=2026-06-01", "host": ["{{baseUrl}}"], "path": ["reservas"], "query": [{ "key": "data", "value": "2026-06-01" }] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', () => pm.response.to.have.status(200));",
        "pm.test('uma reserva', () => pm.expect(pm.response.json()).to.have.lengthOf(1));"
      ] } }]
    },
    {
      "name": "Disponibilidade do dia (slots livres) -> 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/salas/disponibilidade?data=2026-06-01", "host": ["{{baseUrl}}"], "path": ["salas", "disponibilidade"], "query": [{ "key": "data", "value": "2026-06-01" }] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', () => pm.response.to.have.status(200));",
        "pm.test('Sala Azul com 2 intervalos livres', () => { const azul = pm.response.json().find(s => s.id === 1); pm.expect(azul.horariosLivres).to.have.lengthOf(2); });"
      ] } }]
    },
    {
      "name": "Disponibilidade no intervalo 10:30-11:00 (Sala Azul sai) -> 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/salas/disponibilidade?data=2026-06-01&horaInicio=10:30&horaFim=11:00", "host": ["{{baseUrl}}"], "path": ["salas", "disponibilidade"], "query": [{ "key": "data", "value": "2026-06-01" }, { "key": "horaInicio", "value": "10:30" }, { "key": "horaFim", "value": "11:00" }] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', () => pm.response.to.have.status(200));",
        "pm.test('Sala Azul (id 1) nao aparece', () => { const ids = pm.response.json().map(s => s.id); pm.expect(ids).to.not.include(1); });"
      ] } }]
    },
    {

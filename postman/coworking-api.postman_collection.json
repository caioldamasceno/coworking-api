{
  "info": {
    "name": "Coworking API",
    "description": "Colecao de testes ponta a ponta da API de reservas de coworking. Assume o banco H2 em memoria iniciando vazio (a 1a sala cadastrada recebe id=1).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Cadastrar Sala Azul (COLETIVA) -> 201",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"nome\":\"Sala Azul\",\"tipo\":\"COLETIVA\",\"capacidade\":10}" },
        "url": { "raw": "{{baseUrl}}/salas", "host": ["{{baseUrl}}"], "path": ["salas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));",
        "pm.test('id 1', () => pm.expect(pm.response.json().id).to.eql(1));"
      ] } }]
    },
    {
      "name": "Cadastrar Sala Foco (INDIVIDUAL) -> 201",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"nome\":\"Sala Foco\",\"tipo\":\"INDIVIDUAL\",\"capacidade\":4}" },
        "url": { "raw": "{{baseUrl}}/salas", "host": ["{{baseUrl}}"], "path": ["salas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));"
      ] } }]
    },
    {
      "name": "Cadastrar Auditorio Central (AUDITORIO) -> 201",

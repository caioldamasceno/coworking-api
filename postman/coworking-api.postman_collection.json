        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"nome\":\"Auditorio Central\",\"tipo\":\"AUDITORIO\",\"capacidade\":30}" },
        "url": { "raw": "{{baseUrl}}/salas", "host": ["{{baseUrl}}"], "path": ["salas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));"
      ] } }]
    },
    {
      "name": "Cadastrar nome duplicado -> 409",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"nome\":\"Sala Azul\",\"tipo\":\"COLETIVA\",\"capacidade\":8}" },
        "url": { "raw": "{{baseUrl}}/salas", "host": ["{{baseUrl}}"], "path": ["salas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 409', () => pm.response.to.have.status(409));"
      ] } }]
    },
    {
      "name": "Cadastrar capacidade invalida (2) -> 400",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"nome\":\"Sala X\",\"tipo\":\"COLETIVA\",\"capacidade\":2}" },
        "url": { "raw": "{{baseUrl}}/salas", "host": ["{{baseUrl}}"], "path": ["salas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 400', () => pm.response.to.have.status(400));",
        "pm.test('campo capacidade', () => pm.expect(pm.response.json().campos).to.have.property('capacidade'));"
      ] } }]
    },
    {
      "name": "Listar salas (paginado) -> 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/salas?sort=nome,asc", "host": ["{{baseUrl}}"], "path": ["salas"], "query": [{ "key": "sort", "value": "nome,asc" }] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', () => pm.response.to.have.status(200));",
        "pm.test('tem content e totalElements', () => { const b = pm.response.json(); pm.expect(b).to.have.property('content'); pm.expect(b.totalElements).to.eql(3); });"
      ] } }]
    },
    {
      "name": "Listar por tipo INDIVIDUAL -> 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/salas?tipo=INDIVIDUAL", "host": ["{{baseUrl}}"], "path": ["salas"], "query": [{ "key": "tipo", "value": "INDIVIDUAL" }] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', () => pm.response.to.have.status(200));",
        "pm.test('apenas individuais', () => { const c = pm.response.json().content; pm.expect(c).to.have.lengthOf(1); pm.expect(c[0].tipo).to.eql('INDIVIDUAL'); });"
      ] } }]
    },
    {
      "name": "Criar reserva Sala 1 (10:00-11:00) -> 201",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"salaId\":1,\"data\":\"2026-06-01\",\"horaInicio\":\"10:00\",\"horaFim\":\"11:00\",\"responsavel\":\"Caio\",\"email\":\"caio@email.com\"}" },
        "url": { "raw": "{{baseUrl}}/reservas", "host": ["{{baseUrl}}"], "path": ["reservas"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));",
        "pm.test('salaNome preenchido', () => pm.expect(pm.response.json().salaNome).to.eql('Sala Azul'));"
      ] } }]
    },

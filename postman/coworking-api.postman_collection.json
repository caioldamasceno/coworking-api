        "body": { "mode": "raw", "raw": "{\"salaId\":1,\"data\":\"2026-06-01\",\"horaInicio\":\"10:30\",\"horaFim\":\"11:30\",\"responsavel\":\"Ana\",\"email\":\"ana@email.com\"}" },

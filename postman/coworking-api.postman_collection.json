        "body": { "mode": "raw", "raw": "{\"salaId\":1,\"data\":\"2026-06-01\",\"horaInicio\":\"07:00\",\"horaFim\":\"09:00\",\"responsavel\":\"X\",\"email\":\"x@x.com\"}" },
        "url": { "raw": "{{baseUrl}}/reservas", "host": ["{{baseUrl}}"], "path": ["reservas"] }
